{
  "name": "niconicomments-convert",
  "private": false,
  "version": "0.0.34",
  "packageManager": "pnpm@10.33.0",
  "type": "commonjs",
  "license": "MIT",
  "main": "build/electron/electron.js",
  "author": "xpadev(xpadev.net)",
  "homepage": "https://github.com/xpadev-net/niconicomments-convert",
  "scripts": {
    "build:win": "tsc -p electron && pnpm run copy-files && node build-script/win.js",
    "build:mac": "tsc -p electron && pnpm run copy-files && node build-script/mac.js",
    "build": "pnpm run build:win && pnpm run build:mac",
    "copy-files": "rimraf build/electron/html && vite build",
    "check-types": "tsc --noEmit -p ./ && tsc --noEmit -p ./electron",
    "electron:dev": "tsc -p electron&&concurrently \"vite\" \"electron --unhandled-rejections=strict .\"",
    "eslint": "biome lint ./src ./electron",
    "eslint:fix": "biome lint --write --unsafe ./src ./electron",
    "format": "biome format ./src ./electron",
    "format:fix": "biome format --write ./src ./electron",
    "lint": "biome check ./src ./electron",
    "lint:fix": "biome check --write --unsafe ./src ./electron",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@xpadev-net/niconicomments": "^0.2.76",
    "@xpadev-net/xml2js": "0.6.2-2",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "jotai": "^2.19.0",
    "sqlite3": "5.1.6",
    "undici": "^8.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/body-parser": "^1.19.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sqlite3": "^5.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "body-parser": "^2.2.2",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "lefthook": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5"
  },
  "optionalDependencies": {
    "win-protect": "^1.0.0"
  },
  "browserslist": {
    "production": [
      "last 1 electron version"
    ],
    "development": [
      "last 1 electron version"
    ]
  },
  "build": {
    "extraMetadata": {
      "main": "./build/electron/electron.js"
    },
    "files": [
      "build/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "pnpm": {
    "overrides": {
      "@babel/runtime": "7.29.2"
    }
  }
}
